{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GLUT + Sound (UCRT64)",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-IC:/msys64/ucrt64/include",
                "${file}",
                "-LC:/msys64/ucrt64/lib",
                "-lfreeglut",
                "-lopengl32",
                "-lglu32",
                "-lwinmm",
                "-mwindows",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build FreeGLUT/OpenGL + WinMM sound with MSYS2 UCRT64 g++"
        },
        {
            "label": "Build Console C++ (UCRT64)",
            "type": "shell",
